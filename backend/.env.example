# Browserbase — optional bolt-on for live local parts pricing. When both are set,
# the parts panel fetches a live retail price per part; otherwise it falls back
# to the agent's estimate. Get credentials at https://www.browserbase.com/.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Optional: override the price source (must contain a {query} placeholder).
